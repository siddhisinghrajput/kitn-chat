# Server Port & Env
PORT=3000
NODE_ENV=development

# Databases
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kith_db?schema=public"
REDIS_URL="redis://localhost:6379"

# Security & Auth
JWT_SECRET="super-secret-access-token-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-production"

# Anthropic Claude API
ANTHROPIC_API_KEY="your-anthropic-api-key"

# AWS S3 Storage (for Voice Messages)
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_S3_BUCKET="your-s3-bucket-name"
AWS_REGION="us-east-1"

# Auto-Translation Configuration (DeepL or self-hosted LibreTranslate)
DEEPL_API_KEY="your-deepl-api-key"
LIBRETRANSLATE_URL="http://localhost:5000"
